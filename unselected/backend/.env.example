# Use the SAME secret_key in gateway and auth-service so JWTs validate everywhere.
SECRET_KEY=dev-secret-change-in-production

# Optional overrides (defaults match localhost ports below)
AUTH_SERVICE_URL=http://127.0.0.1:8101
STUDY_PLAN_SERVICE_URL=http://127.0.0.1:8102
PROGRESS_SERVICE_URL=http://127.0.0.1:8103
GROUP_SERVICE_URL=http://127.0.0.1:8104
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8105
AI_SERVICE_URL=http://127.0.0.1:8106
